# Copy to deploy/.env on the Hetzner host. Never commit the real .env.
STELE_VERSION=dev
STELE_DB_PASSWORD=change-me-generate-with-openssl-rand-base64-24

# Session HMAC secret. Required (>= 32 bytes). Generate with:
#   openssl rand -base64 48
STELE_SESSION_SECRET=change-me-openssl-rand-base64-48

# Public URL used in password-reset emails.
STELE_BASE_URL=https://stele.178-105-44-164.nip.io

# SMTP (optional). If unset, password reset links land in the app logs.
#STELE_SMTP_HOST=smtp.office365.com
#STELE_SMTP_PORT=587
#STELE_SMTP_USER=stele@your-domain
#STELE_SMTP_PASS=...
#STELE_SMTP_FROM=stele@your-domain

# Documents (ADR-010). Defaults are fine for most cases.
#STELE_DOCS_MAX_BYTES=26214400
